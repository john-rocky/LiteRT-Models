build/
.gradle/
local.properties
.idea/

# Model files (the tflite is pushed to filesDir, never committed)
*.tflite
app/src/main/assets/*.tflite

# Gradle wrapper binary / scripts (not committed)
gradlew
gradlew.bat
gradle/wrapper/gradle-wrapper.jar

